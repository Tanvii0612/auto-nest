# ════════════════════════════════════════════════════════════════
#  AutoNest Backend — Environment Variables
#  Copy this file to .env and fill in your actual values.
#  NEVER commit your real .env file to Git!
# ════════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────────────
# Local MongoDB:
MONGO_URI=mongodb://localhost:27017/autonest

# MongoDB Atlas (cloud) — replace with your connection string:
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/autonest?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ── Razorpay ─────────────────────────────────────────────────
# Get these from: https://dashboard.razorpay.com → Settings → API Keys
#
# TEST MODE keys (start with rzp_test_):
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=your_razorpay_test_secret_key
#
# LIVE MODE keys (start with rzp_live_) — use only in production:
# RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXXXXXX
# RAZORPAY_KEY_SECRET=your_razorpay_live_secret_key
#
# Webhook secret — set this in Razorpay Dashboard → Webhooks
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ── Frontend URL ──────────────────────────────────────────────
# Where your HTML frontend is served (for CORS)
# For local development with Live Server:
FRONTEND_URL=http://127.0.0.1:5500
# For production:
# FRONTEND_URL=https://www.autonest.in
